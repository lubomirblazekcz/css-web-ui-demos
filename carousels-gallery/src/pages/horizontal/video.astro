---
import Layout from "../../layouts/Layout.astro";
import "../../styles/x-carousel.css";

const videos = [
  {
    source: "/carousel/turtle.mp4",
    caption: "It's a turtle!",
  },
  {
    source: "/carousel/snow.mp4",
    caption: "Falling Snow",
  },
  {
    source: "/carousel/wheel.mp4",
    caption: "Ferris Wheel",
  },
  {
    source: "/carousel/chameleon.mp4",
    caption: "I See You",
  },
];
---

<Layout title="Carousel Gallery">
  <section>
    <header>
      <h2>Video Slider</h2>
      <div class="tags">
        <span>Scroll Buttons</span>
        <span>Scroll Driven Animation</span>
        <span>Anchor</span>
        <span>Sticky</span>
      </div>
      <p>
        This example demonstrates a horizontal video slider with scroll buttons.
        Scroll driven animation creates a neat parallax and mask effect as you
        scroll AND scroll driven animation is incrementing a counter to show the
        current page against the total.
      </p>
      <p>
        The first example uses CSS Overflow 5 pseudo-elements. The second uses
        explicit HTML controls enhanced by <code>&lt;x-carousel&gt;</code> so the
        native and polyfilled implementations can be compared one-to-one.
      </p>
    </header>

    <div class="carousel-demos">
      <article class="carousel-demo carousel-demo--native">
        <h3>Native CSS Overflow 5</h3>
        <div role="region" aria-label="Native video carousel demo">
          <div
            class="carousel carousel--native-video carousel--unsnapped-inert"
            aria-live="polite"
          >
            {
              videos.map((video, index) => (
                <div
                  class="carousel__slide"
                  data-label={`Slide ${index + 1}`}
                >
                  <figure
                    class="parallax-item"
                    role="tabpanel"
                    aria-label={`Slide ${index + 1}`}
                  >
                    <video
                      width="1280"
                      height="720"
                      src={video.source}
                      autoplay
                      muted
                      loop
                      playsinline
                    />
                    <figcaption>{video.caption}</figcaption>
                  </figure>
                </div>
              ))
            }
          </div>
        </div>

        <div class="fixed-logo">
          <img
            src="/carousel/googletv-logo.svg"
            alt="Google TV"
            width="300"
            height="52"
          />
        </div>
      </article>

      <article class="carousel-demo">
        <h3>Polyfilled <code>&lt;x-carousel&gt;</code></h3>
        <x-carousel
          id="horizontal-video-polyfill"
          role="region"
          aria-label="Polyfilled video carousel demo"
        >
          <div data-carousel-viewport>
            <div
              class="carousel"
              data-carousel-scroller
              data-inert-unsnapped
              aria-live="polite"
            >
              {
                videos.map((video, index) => (
                  <div
                    id={`polyfill-video-slide-${index + 1}`}
                    class="carousel__slide"
                    data-carousel-slide
                    data-label={`Slide ${index + 1}`}
                  >
                    <figure
                      class="parallax-item"
                      role="tabpanel"
                      aria-label={`Slide ${index + 1}`}
                    >
                      <video
                        width="1280"
                        height="720"
                        src={video.source}
                        autoplay
                        muted
                        loop
                        playsinline
                      />
                      <figcaption>{video.caption}</figcaption>
                    </figure>
                  </div>
                ))
              }
            </div>

            <button
              type="button"
              commandfor="horizontal-video-polyfill"
              command="--prev"
              data-carousel-scroll-button="prev"
              aria-label="Previous slide"
            ></button>
            <button
              type="button"
              commandfor="horizontal-video-polyfill"
              command="--next"
              data-carousel-scroll-button="next"
              aria-label="Next slide"
            ></button>
          </div>

          <output data-carousel-page aria-live="polite">1 / {videos.length}</output>

          <div class="fixed-logo">
            <img
              src="/carousel/googletv-logo.svg"
              alt="Google TV"
              width="300"
              height="52"
            />
          </div>
        </x-carousel>
      </article>
    </div>
  </section>
</Layout>

<script>
  import "../../components/x-carousel";

  const nativeCarousel = document.querySelector<HTMLElement>(
    ".carousel--native-video",
  );
  const polyfilledCarousel = document.querySelector("x-carousel");

  const getNativeSnapTarget = () => {
    if (!nativeCarousel) return;

    const nativeBounds = nativeCarousel.getBoundingClientRect();
    const nativeStyles = getComputedStyle(nativeCarousel);
    const isRtl = nativeStyles.direction === "rtl";
    const scrollPadding =
      Number.parseFloat(nativeStyles.scrollPaddingInlineStart) || 0;
    const snapLine = isRtl
      ? nativeBounds.right - scrollPadding
      : nativeBounds.left + scrollPadding;

    return Array.from(
      nativeCarousel.querySelectorAll<HTMLElement>(":scope > .carousel__slide"),
    ).reduce<{ slide?: HTMLElement; distance: number }>(
      (closest, slide) => {
        const slideBounds = slide.getBoundingClientRect();
        const slideSnapPoint = isRtl ? slideBounds.right : slideBounds.left;
        const distance = Math.abs(slideSnapPoint - snapLine);

        return distance < closest.distance ? { slide, distance } : closest;
      },
      { distance: Number.POSITIVE_INFINITY },
    ).slide;
  };

  const preserveNativeSnapTarget = () => {
    setTimeout(() => {
      const nativeSnapTarget = getNativeSnapTarget();
      if (!nativeSnapTarget) return;

      const { scrollX, scrollY } = window;
      nativeSnapTarget.scrollIntoView({
        behavior: "instant",
        block: "nearest",
        inline: "start",
      });
      window.scrollTo({
        behavior: "instant",
        left: scrollX,
        top: scrollY,
      });
    });
  };

  if (polyfilledCarousel) {
    polyfilledCarousel.addEventListener("click", preserveNativeSnapTarget);
    polyfilledCarousel.addEventListener("focusin", preserveNativeSnapTarget);
  }
</script>

<style>
  @keyframes squeeze {
    entry 0% {
      clip-path: inset(0% 100% 0% 0%);
    }
    entry 100% {
      clip-path: inset(0% 0% 0% 0%);
    }
    exit 0% {
      clip-path: inset(0% 0% 0% 0%);
    }
    exit 100% {
      clip-path: inset(0% 0% 0% 100%);
    }
  }

  @keyframes stay-centered {
    entry 0% {
      translate: -50%;
    }
    entry 100% {
      translate: 0%;
    }
    exit 0% {
      translate: 0%;
    }
    exit 100% {
      translate: 50%;
    }
  }

  @keyframes count-before {
    1%,
    100% {
      counter-increment: page curpage;
    }
  }

  .carousel-demos {
    display: grid;
    gap: var(--size-10);
    min-inline-size: 0;
  }

  .carousel-demo {
    padding-block-end: var(--size-7);
    display: grid;
    gap: var(--size-3);
    min-inline-size: 0;

    > h3 {
      justify-self: center;
      padding-inline: 5vmin;
      text-align: center;
    }
  }

  .carousel-demo--native {
    anchor-scope: --carousel;
  }

  .carousel {
    counter-reset: page curpage;

    display: flex;
    overflow-x: auto;
    scrollbar-width: none;

    border-radius: 20px;
    box-shadow: var(--shadow-6);

    list-style-type: none;
    padding: 0;
    margin: 5vmin;

    @media (width >= 1200px) {
      inline-size: min(80cqi, 1280px);
    }

    .carousel__slide {
      scroll-snap-stop: always;

      padding: 0;
      max-inline-size: initial;

      flex-shrink: 0;
      inline-size: 100cqi;
      aspect-ratio: 16 / 9;
      overflow: clip;

      contain-intrinsic-inline-size: 100cqi;
      content-visibility: auto;
    }
  }

  .carousel--native-video {
    scroll-marker-group: before;

    &::after {
      content: counter(curpage) " / " counter(page);
      position: absolute;
      position-anchor: --carousel;
      position-area: top span-left;
      margin-inline: 30px;
      margin-block: 10px;
    }

    .carousel__slide {
      counter-increment: page;
      animation: count-before linear forwards;
      animation-timeline: view(x);
      animation-range: entry 50% entry 50%;
    }

    &::scroll-button(left) {
      content: "Previous";
      background-image: url(https://api.iconify.design/material-symbols:chevron-left.svg?color=%23ffffff);
      position-area: center span-inline-end;
    }

    &::scroll-button(right) {
      content: "Next";
      background-image: url(https://api.iconify.design/material-symbols:chevron-right.svg?color=%23ffffff);
      position-area: center span-inline-start;
    }

    &::scroll-marker-group {
      content: "Hi";

      position: absolute;
      position-anchor: --carousel;
      inset-block-start: calc(anchor(top) - 30px - 10px);
      inset-inline-end: calc(anchor(right) - 30px);

      display: grid;
      background: none;
    }
  }

  .carousel--native-video::scroll-button(*) {
    background-color: #fff4;
    background-repeat: no-repeat;
    background-position: center;
    background-size: 80%;
    backdrop-filter: blur(10px);

    text-indent: 100vw;
    inline-size: 50px;
    block-size: 50px;
    padding: 0;
    border-radius: 1e3px;
    border: none;

    cursor: pointer;

    position: fixed;
    position-anchor: --carousel;
    margin-inline: 30px;

    transition:
      transform 0.3s var(--ease-spring-3),
      opacity 0.5s var(--ease-3),
      outline-offset 0.25s var(--ease-3);
  }

  x-carousel [data-carousel-scroll-button] {
    background-color: #fff4;
    background-repeat: no-repeat;
    background-position: center;
    background-size: 80%;
    backdrop-filter: blur(10px);

    text-indent: 100vw;
    inline-size: 50px;
    block-size: 50px;
    padding: 0;
    border-radius: 1e3px;
    border: none;

    cursor: pointer;

    position: fixed;
    position-anchor: --carousel;
    margin-inline: 30px;

    transition:
      transform 0.3s var(--ease-spring-3),
      opacity 0.5s var(--ease-3),
      outline-offset 0.25s var(--ease-3);
  }

  x-carousel [data-carousel-scroll-button="prev"] {
    background-image: url(https://api.iconify.design/material-symbols:chevron-left.svg?color=%23ffffff);
    position-area: center span-inline-end;
  }

  x-carousel [data-carousel-scroll-button="next"] {
    background-image: url(https://api.iconify.design/material-symbols:chevron-right.svg?color=%23ffffff);
    position-area: center span-inline-start;
  }

  .carousel--native-video::scroll-button(*):is(:hover, :focus-visible) {
    background-color: #fff3;
    transform: scale(1.1);
  }

  x-carousel:has([data-carousel-scroll-button]:is(:hover, :focus-visible))
    [data-carousel-scroll-button]:not(:disabled) {
    background-color: #fff3;
    transform: scale(1.1);
  }

  .carousel--native-video::scroll-button(*):focus-visible:not(:active) {
    outline-offset: 2px;
    outline: 2px solid var(--link);
  }

  x-carousel [data-carousel-scroll-button]:focus-visible:not(:active) {
    outline-offset: 2px;
    outline: 2px solid var(--link);
  }

  .carousel--native-video::scroll-button(right):active {
    transform: translateX(5px) scale(0.95);
  }

  x-carousel [data-carousel-scroll-button="next"]:active {
    transform: translateX(5px) scale(0.95);
  }

  .carousel--native-video::scroll-button(left):active {
    transform: translateX(-5px) scale(0.95);
  }

  x-carousel [data-carousel-scroll-button="prev"]:active {
    transform: translateX(-5px) scale(0.95);
  }

  .carousel--native-video::scroll-button(*):disabled {
    opacity: 0%;
    cursor: not-allowed;
  }

  x-carousel [data-carousel-scroll-button]:disabled {
    opacity: 0%;
    cursor: not-allowed;
  }

  x-carousel [data-carousel-page] {
    position: absolute;
    position-anchor: --carousel;
    position-area: top span-left;
    margin-inline: 30px;
    margin-block: 10px;
  }

  .parallax-item {
    display: grid;
    place-items: end start;

    > * {
      grid-area: 1/1;
    }

    > video {
      inline-size: 100%;
      block-size: 100%;
      object-fit: cover;
    }

    > figcaption {
      padding: 30px;
      font-size: 1.5rem;
      font-weight: 200;

      position: sticky;
      left: 0;
    }
  }

  @supports ((animation-timeline: view()) and (animation-range: entry)) {
    @media (prefers-reduced-motion: no-preference) {
      .parallax-item {
        animation: squeeze linear both;
        animation-timeline: view(inline);
        timeline-scope: --parallax-item;

        & video {
          animation: stay-centered linear both;
          animation-timeline: view(x);
          timeline-scope: --parallax-item;
        }
      }
    }
  }

  .fixed-logo {
    position: fixed;
    position-anchor: --carousel;

    inset-block-start: calc(anchor(top) + 30px);
    inset-inline-start: calc(anchor(left) + 30px);

    max-inline-size: 150px;
  }
</style>
